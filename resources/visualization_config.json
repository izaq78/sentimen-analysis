{
  "output_directory": "hasil_visualisasi",
  "output_files": {
    "label_distribution": "1_label_distribution.png",
    "review_length_histogram": "2_review_length_histogram.png",
    "review_length_boxplot": "3_review_length_boxplot.png",
    "top_words": "4_top20_words.png",
