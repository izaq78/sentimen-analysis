  },
  "palette": {
    "label_distribution": ["#2ecc71", "#e74c3c"],
    "histogram": "#3498db",
    "boxplot": "#9b59b6",
    "top_words": "viridis",
    "model_metrics": "magma",
    "confusion_matrix": "Blues",
    "confusion_matrix_values_format": "d"
